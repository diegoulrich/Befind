# Required for the API server
OPENAI_API_KEY=sk-your-openai-key
DATABASE_URL=postgresql://user:password@host:5432/database
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret

# Comma-separated emails that always get Premium access without Stripe checkout.
OWNER_PREMIUM_EMAILS=diego.ulrich.03@gmail.com

# SMTP email sending for the contact form.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=befind.business@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=befind.business@gmail.com

# Optional local settings
PORT=3001
LOG_LEVEL=info
NODE_ENV=development

# Stripe is read through the Replit Stripe integration in this codebase.
# Connect Stripe from Replit's Integrations tab so these values are provided:
# REPLIT_CONNECTORS_HOSTNAME
# REPL_IDENTITY or WEB_REPL_RENEWAL
